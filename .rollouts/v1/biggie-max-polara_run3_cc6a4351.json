{"evaluation_id": "27615e12-de7e-4b29-8ef7-900fe5870d0e", "run_number": 3, "score": 0.7316556270573464, "grade_result": {"metadata": {"feedback": {"score": 0.7316556270573464, "submission": "\"\"\"\nBudgeted feature-acquisition classifier for /data_agent/unsw.\n\nObservation about this problem:\n  - budget = 2.0\n  - Three features have cost 0: {7, 11, 21}. They should always be acquired.\n  - 27 features have cost 2 (the whole budget). 12 features have cost 4 and are\n    therefore unaffordable given the 2.0 budget starting from scratch.\n  - So each case ends up with exactly the three zero-cost features + at most one\n    chosen cost-2 feature.\n\nStrategy:\n  1. In __init__, train one XGBoost classifier per candidate cost-2 feature f, on\n     features {zero-cost \u222a {f}} with balanced class weights.  This gives 27 small\n     classifiers.\n  2. Also compute, via 5-fold OOF, the per-feature correctness of each classifier\n     on every training row, and use that to build a lookup table:\n       (val of feat 7, val of feat 11, val of feat 21)  ->  best cost-2 feature.\n     With shrinkage toward the global per-f accuracy so rare states don't overfit.\n  3. At inference:\n       - select_next: first acquire the zero-cost features in any order (they are\n         free); then, once we have their values, look up the best cost-2 feature\n         for that state and acquire it if we can afford it; then stop.\n       - predict: run the model corresponding to the acquired cost-2 feature on\n         (zero, f) and return argmax.  If no cost-2 feature was acquired (e.g.\n         budget insufficient), use a zero-feature-only model.\n\"\"\"\nfrom __future__ import annotations\n\nimport json\nimport os\nfrom collections import defaultdict\nfrom typing import Optional\n\nimport numpy as np\nimport xgboost as xgb\nfrom sklearn.model_selection import StratifiedKFold\n\n\nclass Policy:\n    def __init__(self, data_dir: str):\n        self.data_dir = data_dir\n\n        # ---------------------- load data & meta ----------------------\n        meta = json.load(open(os.path.join(data_dir, \"meta.json\")))\n        self.n_features: int = int(meta[\"n_features\"])\n        self.n_classes: int = int(meta[\"n_classes\"])\n        self.costs: np.ndarray = np.asarray(meta[\"costs\"], dtype=float)\n        self.budget: float = float(meta[\"budget\"])\n\n        X_tr = np.load(os.path.join(data_dir, \"train_features.npy\"))\n        y_tr = np.load(os.path.join(data_dir, \"train_labels.npy\")).astype(int)\n        X_va = np.load(os.path.join(data_dir, \"val_features.npy\"))\n        y_va = np.load(os.path.join(data_dir, \"val_labels.npy\")).astype(int)\n        X = np.concatenate([X_tr, X_va], axis=0)\n        y = np.concatenate([y_tr, y_va], axis=0)\n        n = len(X)\n\n        # ---------------------- categorize features -------------------\n        zero_feats = np.where(self.costs == 0.0)[0].tolist()\n        # Only cost-2 features are affordable one-at-a-time under budget=2.0.\n        # More generally: any single feature whose cost <= budget (and > 0).\n        affordable = [\n            int(i) for i in range(self.n_features)\n            if 0.0 < self.costs[i] <= self.budget + 1e-9\n        ]\n        # Among affordable, prefer the cheapest tier(s) (they consume the least\n        # budget and behave the same here since budget=2).\n        # We'll build a candidate model per affordable feature.\n        self.zero_feats: list[int] = zero_feats\n        self.candidate_feats: list[int] = affordable\n\n        # Balanced-class sample weights.\n        counts = np.bincount(y, minlength=self.n_classes).astype(float)\n        # avoid /0\n        counts[counts == 0] = 1.0\n        cls_w = n / (self.n_classes * counts)\n        w = cls_w[y]\n        self._cls_w = cls_w\n\n        # ---------------------- OOF per candidate feature -------------\n        # 5-fold stratified OOF probabilities for each (zero + f) model.\n        skf = StratifiedKFold(n_splits=5, shuffle=True, random_state=0)\n        oof_correct = np.zeros((n, len(self.candidate_feats)), dtype=np.float32)\n        for tr_idx, te_idx in skf.split(X, y):\n            for k, f in enumerate(self.candidate_feats):\n                cols = zero_feats + [int(f)]\n                mm = xgb.XGBClassifier(\n                    n_estimators=400, max_depth=6, learning_rate=0.1,\n                    n_jobs=4, tree_method=\"hist\", verbosity=0,\n                )\n                mm.fit(X[tr_idx][:, cols], y[tr_idx], sample_weight=w[tr_idx])\n                p = mm.predict_proba(X[te_idx][:, cols])\n                oof_correct[te_idx, k] = (p.argmax(1) == y[te_idx]).astype(np.float32)\n\n        # ---------------------- full models on all data ---------------\n        self._models: dict[int, xgb.XGBClassifier] = {}\n        for f in self.candidate_feats:\n            cols = zero_feats + [int(f)]\n            mm = xgb.XGBClassifier(\n                n_estimators=400, max_depth=6, learning_rate=0.1,\n                n_jobs=4, tree_method=\"hist\", verbosity=0,\n            )\n            mm.fit(X[:, cols], y, sample_weight=w)\n            self._models[int(f)] = mm\n\n        # Zero-only fallback model (used if we never acquire any cost-2 feature).\n        if zero_feats:\n            m0 = xgb.XGBClassifier(\n                n_estimators=400, max_depth=6, learning_rate=0.1,\n                n_jobs=4, tree_method=\"hist\", verbosity=0,\n            )\n            m0.fit(X[:, zero_feats], y, sample_weight=w)\n            self._model_zero_only: Optional[xgb.XGBClassifier] = m0\n        else:\n            self._model_zero_only = None\n\n        # Full-population (empty observation) fallback: predict majority weighted class.\n        # We store class priors weighted by balanced weights (all uniform here).\n        self._prior_pred: int = int(np.argmax(cls_w * counts))\n        # (equivalent to majority in balanced sense; but we simply pick 0..K-1\n        # that maximizes uniformly-weighted count, i.e., majority.)\n        self._majority_class: int = int(np.argmax(counts))\n\n        # ---------------------- build state -> best-f lookup ----------\n        # For each observed (zero_feats) tuple, compute class-balanced correctness\n        # per candidate f, smooth toward the global-best f, and take argmax.\n        state_groups: dict[tuple, list[int]] = defaultdict(list)\n        for i in range(n):\n            state_groups[tuple(X[i, zero_feats].tolist())].append(i)\n\n        global_score = (oof_correct * w[:, None]).sum(0) / max(w.sum(), 1e-9)\n        alpha = 50.0\n        self._state_best: dict[tuple, int] = {}\n        for st, idxs in state_groups.items():\n            ww = cls_w[y[idxs]]\n            wc = (oof_correct[idxs] * ww[:, None]).sum(0)\n            wt = ww.sum()\n            smoothed = (wc + alpha * global_score) / (wt + alpha)\n            self._state_best[st] = int(self.candidate_feats[int(smoothed.argmax())])\n        self._default_f: int = int(self.candidate_feats[int(global_score.argmax())])\n\n        # For future extensions: keep zero_feats/candidate_feats ordered for\n        # deterministic selection.\n        self._zero_order = list(zero_feats)\n\n    # -------------------------- policy interface -------------------------\n    def select_next(self, observed: dict, budget_left: float) -> Optional[int]:\n        # 1) If any zero-cost feature is affordable and not yet observed, grab it.\n        #    (Cost 0 means budget never decreases; taking them can only help.)\n        for f in self._zero_order:\n            if f not in observed and self.costs[f] <= budget_left + 1e-12:\n                return int(f)\n\n        # 2) All zero-cost features observed: choose the best cost-2 feature\n        #    conditioned on their values.\n        # If we already picked a cost-2 feature (in observed), we're done.\n        for f in observed:\n            if f in self._models:  # any candidate cost-2 feat already observed\n                return None\n\n        # Build the state tuple from observed zero-cost features.\n        try:\n            state = tuple(float(observed[f]) for f in self._zero_order)\n        except KeyError:\n            # Not all zero features observed (edge case if some have cost > 0 unexpectedly).\n            state = None\n\n        if state is not None:\n            f_best = self._state_best.get(state, self._default_f)\n        else:\n            f_best = self._default_f\n\n        # Only acquire if affordable.\n        if self.costs[f_best] <= budget_left + 1e-12:\n            return int(f_best)\n\n        # If the state's best f is unaffordable, look for any affordable\n        # candidate ranked by global score.\n        # (Shouldn't happen for budget=2 and cost-2 candidates, but be safe.)\n        # We enumerate candidates by global preference.\n        for f in self.candidate_feats:\n            if self.costs[f] <= budget_left + 1e-12 and f not in observed:\n                return int(f)\n        return None\n\n    def predict(self, observed: dict) -> int:\n        # Case A: we have zero features + exactly one candidate cost-2 feature.\n        chosen_f = None\n        for f in observed:\n            if f in self._models:\n                chosen_f = int(f)\n                break\n\n        if chosen_f is not None:\n            cols = self._zero_order + [chosen_f]\n            # Fill row with observed values; unobserved zero features (unlikely) -> NaN.\n            row = np.full((1, self.n_features), np.nan, dtype=np.float32)\n            for k, v in observed.items():\n                row[0, int(k)] = float(v)\n            x = row[:, cols]\n            # If any of the zero features are missing, XGBoost handles NaN natively.\n            return int(self._models[chosen_f].predict(x)[0])\n\n        # Case B: only zero features observed (no affordable cost-2 pick).\n        if self._model_zero_only is not None and all(f in observed for f in self._zero_order):\n            row = np.array([[float(observed[f]) for f in self._zero_order]], dtype=np.float32)\n            return int(self._model_zero_only.predict(row)[0])\n\n        # Case C: nothing (or partial zero features). Predict majority class.\n        # Better: use the zero-only model with NaNs for the missing ones.\n        if self._model_zero_only is not None and self._zero_order:\n            row = np.full((1, len(self._zero_order)), np.nan, dtype=np.float32)\n            for i, f in enumerate(self._zero_order):\n                if f in observed:\n                    row[0, i] = float(observed[f])\n            return int(self._model_zero_only.predict(row)[0])\n\n        return self._majority_class\n\n", "predictions_b64": ""}}}}