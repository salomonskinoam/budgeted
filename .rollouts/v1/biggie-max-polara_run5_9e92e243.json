{"evaluation_id": "27615e12-de7e-4b29-8ef7-900fe5870d0e", "run_number": 5, "score": 0.7325343104313181, "grade_result": {"metadata": {"feedback": {"score": 0.7325343104313181, "submission": "\"\"\"\nCost-aware feature acquisition policy for the UNSW multi-class classification problem.\n\nDesign:\n- Budget=2. Free features (cost=0): always acquire (no budget spent).\n- With budget=2 we can afford exactly one cost=2 feature or zero cost=4 features.\n- For each cost=2 candidate feature f, train a dedicated XGBoost classifier on\n  (free_features + f) with balanced sample weights.\n- Use the free-only classifier's class-probability to compute expected balanced-accuracy\n  reward for each candidate f (using its OOF per-class recall) and pick the argmax.\n- At prediction time, use the classifier matching the observed feature set.\n\"\"\"\nimport os\nimport json\nimport numpy as np\n\n\nclass Policy:\n    def __init__(self, data_dir):\n        import xgboost as xgb\n        from sklearn.model_selection import StratifiedKFold\n\n        self._xgb = xgb\n\n        # Load data and metadata\n        meta_path = os.path.join(data_dir, \"meta.json\")\n        with open(meta_path, \"r\") as fh:\n            meta = json.load(fh)\n        self.costs = np.asarray(meta[\"costs\"], dtype=np.float64)\n        self.n_features = int(meta[\"n_features\"])\n        self.n_classes = int(meta[\"n_classes\"])\n        self.budget = float(meta[\"budget\"])\n\n        Xtr = np.load(os.path.join(data_dir, \"train_features.npy\")).astype(np.float32)\n        ytr = np.load(os.path.join(data_dir, \"train_labels.npy\")).astype(np.int64)\n        Xva = np.load(os.path.join(data_dir, \"val_features.npy\")).astype(np.float32)\n        yva = np.load(os.path.join(data_dir, \"val_labels.npy\")).astype(np.int64)\n        # Use combined data for final training (val is training data)\n        X = np.vstack([Xtr, Xva])\n        y = np.concatenate([ytr, yva])\n        n = X.shape[0]\n\n        # Partition features by cost\n        self.free_feats = [i for i in range(self.n_features) if self.costs[i] == 0.0]\n        self.cost2_feats = [i for i in range(self.n_features) if self.costs[i] == 2.0]\n        self.cost4_feats = [i for i in range(self.n_features) if self.costs[i] == 4.0]\n\n        # Balanced sample weights (so classifiers optimise for balanced accuracy)\n        class_counts = np.bincount(y, minlength=self.n_classes).astype(np.float64)\n        # avoid divide by zero\n        cw = 1.0 / np.where(class_counts > 0, class_counts, 1.0)\n        cw = cw / cw.sum() * self.n_classes\n        sw = cw[y]\n        self.class_counts = class_counts\n\n        def make_clf(n_est=500, md=6, lr=0.05):\n            return xgb.XGBClassifier(\n                n_estimators=n_est, max_depth=md, learning_rate=lr,\n                tree_method=\"hist\", n_jobs=os.cpu_count() or 4,\n                eval_metric=\"mlogloss\", verbosity=0, reg_lambda=1.0,\n            )\n\n        # Train one classifier per cost-2 candidate feature: input = free_feats + [f]\n        self.clfs_f = {}\n        for f in self.cost2_feats:\n            cols = self.free_feats + [f]\n            clf = make_clf()\n            clf.fit(X[:, cols], y, sample_weight=sw)\n            self.clfs_f[f] = clf\n\n        # Free-only classifier\n        self.clf_free = make_clf()\n        self.clf_free.fit(X[:, self.free_feats], y, sample_weight=sw)\n\n        # Compute per-class recall (accuracy on class c) for each cost-2 feature via OOF\n        # so the selection is unbiased.\n        oof_preds = np.zeros((len(self.cost2_feats), n), dtype=np.int64)\n        skf = StratifiedKFold(n_splits=3, shuffle=True, random_state=7)\n        for tr_idx, va_idx in skf.split(X, y):\n            for fi, f in enumerate(self.cost2_feats):\n                cols = self.free_feats + [f]\n                clf = make_clf(n_est=400)\n                clf.fit(X[tr_idx][:, cols], y[tr_idx], sample_weight=sw[tr_idx])\n                oof_preds[fi, va_idx] = clf.predict(X[va_idx][:, cols])\n\n        per_class_acc = np.zeros((len(self.cost2_feats), self.n_classes), dtype=np.float32)\n        for fi in range(len(self.cost2_feats)):\n            for c in range(self.n_classes):\n                m = y == c\n                if m.sum() > 0:\n                    per_class_acc[fi, c] = (oof_preds[fi, m] == c).mean()\n        self.per_class_acc = per_class_acc  # (F, C)\n\n        # Balanced-accuracy weighting: recall of class c contributes 1/n_c to the raw sum\n        # of correct-class indicators (i.e. weight for expected reward is 1/n_c).\n        self.w_c = (1.0 / np.where(class_counts > 0, class_counts, 1.0)).astype(np.float32)\n\n        # Fallback: masked-input classifier (used only if the observed set doesn't match any dedicated classifier)\n        rng = np.random.default_rng(0)\n        X_list = [X]\n        y_list = [y]\n        sw_list = [sw]\n        # free-only replicate\n        Xm = np.full_like(X, np.nan)\n        for ff in self.free_feats:\n            Xm[:, ff] = X[:, ff]\n        X_list.append(Xm); y_list.append(y); sw_list.append(sw)\n        # free + one cost-2 (per row uniform choice), several replicas\n        for _ in range(3):\n            Xm = np.full_like(X, np.nan)\n            for ff in self.free_feats:\n                Xm[:, ff] = X[:, ff]\n            fs = rng.choice(self.cost2_feats, size=n)\n            Xm[np.arange(n), fs] = X[np.arange(n), fs]\n            X_list.append(Xm); y_list.append(y); sw_list.append(sw)\n        Xa = np.vstack(X_list); ya = np.concatenate(y_list); swa = np.concatenate(sw_list)\n        self.clf_mask = make_clf(n_est=500)\n        self.clf_mask.fit(Xa, ya, sample_weight=swa)\n\n        # Precompute per-class-acc x w_c for expected-reward scoring\n        # (F, C) * (C,) -> element-wise on class axis; keep (F, C)\n        self._wpca = self.per_class_acc * self.w_c[None, :]  # (F, C)\n\n        # Sanity fallback: if free-only prediction is unreliable, use uniform prior\n        self._uniform_p = np.ones(self.n_classes, dtype=np.float32) / self.n_classes\n\n    # ------------------------------------------------------------------\n    def _observed_vec(self, observed):\n        \"\"\"Turn observed dict into a full-length feature vector with NaN for missing.\"\"\"\n        v = np.full(self.n_features, np.nan, dtype=np.float32)\n        for k, val in observed.items():\n            v[k] = val\n        return v\n\n    def _free_proba(self, observed):\n        \"\"\"Return class posterior using free features only (if any observed).\"\"\"\n        v = self._observed_vec(observed)\n        xf = v[self.free_feats][None, :]\n        # If any free feature is NaN (they should all have been acquired), fall back to mask model\n        if np.any(np.isnan(xf)):\n            xmask = v[None, :]\n            p = self.clf_mask.predict_proba(xmask)[0]\n        else:\n            p = self.clf_free.predict_proba(xf)[0]\n        return p.astype(np.float32)\n\n    # ------------------------------------------------------------------\n    def select_next(self, observed, budget_left):\n        \"\"\"\n        Acquisition policy:\n        1. Acquire every free (cost=0) feature first (they don't consume budget).\n        2. Then, if we can still afford one cost-2 feature, pick the one that maximises\n           expected balanced-accuracy reward given the free features already observed.\n        3. Otherwise stop.\n        \"\"\"\n        # Step 1: acquire any remaining free feature\n        for f in self.free_feats:\n            if f not in observed:\n                # Cost is 0, always affordable but double-check\n                if self.costs[f] <= budget_left + 1e-9:\n                    return f\n\n        # Step 2: pick one cost-2 feature if we haven't already\n        already_cost2 = [f for f in observed.keys() if self.costs[f] == 2.0]\n        already_cost4 = [f for f in observed.keys() if self.costs[f] == 4.0]\n\n        if len(already_cost2) == 0 and len(already_cost4) == 0 and budget_left >= 2.0 - 1e-9:\n            p_free = self._free_proba(observed)\n            # Expected reward per candidate f: sum_c p_free(c) * w_c * per_class_acc(f, c)\n            expected_reward = self._wpca @ p_free  # (F,)\n            best_fi = int(np.argmax(expected_reward))\n            f_best = self.cost2_feats[best_fi]\n            if self.costs[f_best] <= budget_left + 1e-9:\n                return f_best\n\n        # No further acquisitions\n        return None\n\n    # ------------------------------------------------------------------\n    def predict(self, observed):\n        \"\"\"Predict the class using the best-matching classifier for the observed set.\"\"\"\n        free_ok = all(f in observed for f in self.free_feats)\n        acquired_cost2 = [f for f in observed.keys() if self.costs[f] == 2.0]\n        acquired_cost4 = [f for f in observed.keys() if self.costs[f] == 4.0]\n\n        # Case 1: exactly free + one cost-2 -> use dedicated classifier\n        if free_ok and len(acquired_cost2) == 1 and len(acquired_cost4) == 0:\n            f = acquired_cost2[0]\n            if f in self.clfs_f:\n                cols = self.free_feats + [f]\n                v = self._observed_vec(observed)\n                x = v[cols][None, :]\n                return int(self.clfs_f[f].predict(x)[0])\n\n        # Case 2: exactly free-only -> free classifier\n        if free_ok and len(acquired_cost2) == 0 and len(acquired_cost4) == 0:\n            v = self._observed_vec(observed)\n            x = v[self.free_feats][None, :]\n            return int(self.clf_free.predict(x)[0])\n\n        # Case 3: anything else -> masked fallback classifier\n        v = self._observed_vec(observed)\n        return int(self.clf_mask.predict(v[None, :])[0])\n\n", "predictions_b64": ""}}}}