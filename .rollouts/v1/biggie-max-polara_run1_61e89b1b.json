{"evaluation_id": "27615e12-de7e-4b29-8ef7-900fe5870d0e", "run_number": 1, "score": 0.7311741108740595, "grade_result": {"metadata": {"feedback": {"score": 0.7311741108740595, "submission": "\"\"\"Cost-budgeted classifier policy for UNSW-like dataset.\n\nDesign:\n- Budget is 2.0 per case. Zero-cost features {7, 11, 21} are always acquired.\n- Cost-2 features can afford exactly one; cost-4 features are unaffordable.\n- After observing the free features, we choose a cost-2 feature via a small\n  learned decision tree (`_pick_cost2_feat`) whose splits are on the free\n  feature values. Leaves point to one of {34, 12, 3, 25}.\n- We train a specialized HGB ensemble (multi-seed) for each leaf feature over\n  (free_features + that_cost2_feature) using the fully observed train+val data.\n- `predict` picks the classifier matching which cost-2 feature was actually\n  acquired (if none, fall back to a free-only ensemble).\n\"\"\"\n\nimport json\nimport os\nimport numpy as np\nimport warnings\nwarnings.filterwarnings(\"ignore\")\n\nfrom sklearn.ensemble import HistGradientBoostingClassifier\n\n\n# ------------- Feature groupings (from meta.json for UNSW) ------------------\n# We infer these dynamically in __init__ but keep constants as fallback.\n_FREE_FALLBACK = [7, 11, 21]                      # cost 0\n_LEAF_FEATS_FALLBACK = [3, 12, 25, 34]            # cost 2 features referenced by the tree\n\n\nclass _Ensemble:\n    \"\"\"Multi-seed HGB ensemble that averages predict_proba.\"\"\"\n    def __init__(self, feats, n_seeds=5, max_iter=500, lr=0.05, max_leaf_nodes=31, l2=0.5):\n        self.feats = list(feats)\n        self.n_seeds = n_seeds\n        self.max_iter = max_iter\n        self.lr = lr\n        self.max_leaf_nodes = max_leaf_nodes\n        self.l2 = l2\n        self.clfs_ = []\n        self.classes_ = None\n\n    def fit(self, X, y):\n        Xs = X[:, self.feats]\n        for s in range(self.n_seeds):\n            c = HistGradientBoostingClassifier(\n                max_iter=self.max_iter,\n                max_leaf_nodes=self.max_leaf_nodes,\n                learning_rate=self.lr,\n                class_weight=\"balanced\",\n                random_state=s,\n                l2_regularization=self.l2,\n            )\n            c.fit(Xs, y)\n            self.clfs_.append(c)\n        self.classes_ = self.clfs_[0].classes_\n        return self\n\n    def predict_proba_row(self, values_by_feat):\n        \"\"\"values_by_feat: dict feat_id -> value. Missing feats filled with 0.0 (rare).\"\"\"\n        x = np.zeros((1, len(self.feats)), dtype=np.float64)\n        for i, f in enumerate(self.feats):\n            if f in values_by_feat:\n                x[0, i] = values_by_feat[f]\n            else:\n                x[0, i] = 0.0\n        probs = np.mean([c.predict_proba(x)[0] for c in self.clfs_], axis=0)\n        return probs\n\n    def predict_row(self, values_by_feat):\n        return int(self.classes_[int(np.argmax(self.predict_proba_row(values_by_feat)))])\n\n\nclass Policy:\n    def __init__(self, data_dir):\n        # ---- Load meta ----\n        with open(os.path.join(data_dir, \"meta.json\"), \"r\") as f:\n            meta = json.load(f)\n        self.n_features = meta[\"n_features\"]\n        self.n_classes = meta[\"n_classes\"]\n        self.budget = float(meta[\"budget\"])\n        self.costs = np.asarray(meta[\"costs\"], dtype=np.float64)\n\n        # ---- Load data (train + val, both fully observed) ----\n        Xtr = np.load(os.path.join(data_dir, \"train_features.npy\"))\n        ytr = np.load(os.path.join(data_dir, \"train_labels.npy\"))\n        X, y = Xtr, ytr\n        # Also include val (fully observed labeled data) - we've already done all\n        # model selection using OOF on train, so training on train+val is fine.\n        try:\n            Xv = np.load(os.path.join(data_dir, \"val_features.npy\"))\n            yv = np.load(os.path.join(data_dir, \"val_labels.npy\"))\n            X = np.vstack([Xtr, Xv])\n            y = np.concatenate([ytr, yv])\n        except FileNotFoundError:\n            pass\n\n        # ---- Identify feature groups by cost ----\n        self.free_feats = [i for i in range(self.n_features) if self.costs[i] == 0.0]\n        self.cost2_feats = [i for i in range(self.n_features)\n                            if 0.0 < self.costs[i] <= self.budget]\n\n        # The learned decision tree uses features 7, 11 from free set and leaf features 3,12,25,34.\n        # Guard: if the environment differs, fall back to feature 25 always.\n        self._use_tree = (\n            len(self.free_feats) >= 2\n            and 7 in self.free_feats and 11 in self.free_feats\n            and all(f in self.cost2_feats for f in _LEAF_FEATS_FALLBACK)\n        )\n\n        # ---- Train specialized ensembles for each leaf cost-2 feature ----\n        self.leaf_feats = list(_LEAF_FEATS_FALLBACK) if self._use_tree else []\n        # Ensure we also have a default cost-2 fallback trained\n        default_cost2 = 25 if 25 in self.cost2_feats else (self.cost2_feats[0] if self.cost2_feats else None)\n        if default_cost2 is not None and default_cost2 not in self.leaf_feats:\n            self.leaf_feats.append(default_cost2)\n        self.default_cost2 = default_cost2\n\n        self.ensembles = {}  # cost2_feat -> _Ensemble\n        for f in self.leaf_feats:\n            feats = self.free_feats + [f]\n            ens = _Ensemble(feats, n_seeds=3, max_iter=400, lr=0.05, max_leaf_nodes=31, l2=0.5)\n            ens.fit(X, y)\n            self.ensembles[f] = ens\n\n        # Free-only ensemble (fallback in case no cost-2 acquired)\n        self.free_ensemble = _Ensemble(self.free_feats, n_seeds=3, max_iter=400, lr=0.05, max_leaf_nodes=31, l2=0.5)\n        self.free_ensemble.fit(X, y)\n\n        # Also train an \"empty\" fallback: majority-class by ensemble on all features\n        # But if no free-feat acquired we'll just predict the most common class.\n        vals, cnts = np.unique(y, return_counts=True)\n        self.majority_class = int(vals[int(np.argmax(cnts))])\n\n    # -------- Tree policy for choosing cost-2 feature ---------\n    def _pick_cost2_feat(self, observed):\n        \"\"\"Given observed dict (includes free-feat values), return preferred cost-2 feat id.\"\"\"\n        if not self._use_tree:\n            return self.default_cost2\n\n        v7 = observed.get(7, 0.0)\n        v11 = observed.get(11, 0.0)\n        # Tree derived on training data:\n        #   if feat7 < 1:\n        #       if feat11 < 5: -> feat 34\n        #       else:          -> feat 12\n        #   else:              -> feat 3\n        if v7 < 1.0:\n            if v11 < 5.0:\n                return 34\n            else:\n                return 12\n        else:\n            return 3\n\n    # -------- Interface --------\n    def select_next(self, observed, budget_left):\n        # 1) grab free features first\n        for f in self.free_feats:\n            if f not in observed and self.costs[f] <= budget_left:\n                return int(f)\n\n        # 2) if we already spent budget, stop\n        # 3) choose a cost-2 feature via the tree\n        preferred = self._pick_cost2_feat(observed)\n        if (\n            preferred is not None\n            and preferred not in observed\n            and self.costs[preferred] <= budget_left\n        ):\n            return int(preferred)\n\n        # 4) if preferred isn't affordable/available, pick cheapest available cost-2 feature we can afford\n        available_cost2 = [f for f in self.cost2_feats\n                           if f not in observed and self.costs[f] <= budget_left]\n        if available_cost2:\n            # pick the one closest to preferred, or just default\n            if self.default_cost2 in available_cost2:\n                return int(self.default_cost2)\n            return int(available_cost2[0])\n\n        # 5) done\n        return None\n\n    def predict(self, observed):\n        # Determine which specialized ensemble to use based on which leaf cost-2 feat is observed.\n        chosen = None\n        # Prefer using the ensemble matching the feature we actually acquired\n        for f in self.leaf_feats:\n            if f in observed:\n                chosen = f\n                break\n        if chosen is not None:\n            ens = self.ensembles[chosen]\n            return ens.predict_row(observed)\n\n        # If we somehow have no leaf-feat but do have free feats, use free-only ensemble\n        if any(f in observed for f in self.free_feats):\n            return self.free_ensemble.predict_row(observed)\n\n        # Fully blind (shouldn't happen since free feats cost 0)\n        return self.majority_class\n\n\n\n\n\n", "predictions_b64": ""}}}}